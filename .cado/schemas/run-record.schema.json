{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/cado/schemas/run-record.schema.json",
  "title": "CADO Framework Run Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "stage",
    "intent",
    "plan_summary",
    "delegations",
    "approvals",
    "evidence",
    "ship_summary"
  ],
  "properties": {
    "run_id": {
      "type": "string"
    },
    "stage": {
      "type": "string",
      "enum": [
        "Intake",
        "Plan",
        "Gate",
        "Build",
        "Prove",
        "Ship"
      ]
    },
    "intent": {
      "type": "string"
    },
    "plan_summary": {
      "type": "string"
    },
    "delegations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "specialist",
          "scope",
          "when"
        ],
        "properties": {
          "specialist": {
            "type": "string"
          },
          "scope": {
            "type": "string"
          },
          "when": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "approvals": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "mechanism",
          "status"
        ],
        "properties": {
          "mechanism": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "by": {
            "type": "string"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "$ref": "evidence.schema.json"
      }
    },
    "ship_summary": {
      "type": "string"
    }
  }
}

