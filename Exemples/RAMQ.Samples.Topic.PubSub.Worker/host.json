{
  "version": "2.0",
  "logging": {
    "logLevel": {
      "RAMQ": "Information",
      "Azure.Identity": "None",
      "Microsoft.Identity": "None",
      "ApplicationInsights": "Warning",
      "Grpc": "None",
      "Microsoft.Azure.Functions.Worker.Grpc": "None"
    },
    "applicationInsights": {
      "samplingSettings": {
        "isEnabled": true,
        "excludedTypes": "Exception;Request",
        "maxTelemetryItemsPerSecond": 5
      },
      "enableLiveMetricsFilters": true
    }
  }
}
