<Project>
  <!--
    Workaround for Extensions.DurableTask 1.1.7 + Microsoft.NET.Sdk.Functions 4.6.0 on .NET 8.

    The WorkerExtensions inner project (auto-generated by the SDK) resolves
    System.Security.Cryptography.ProtectedData 4.7.0. The SDK's _FunctionsPostBuildCopyFiles
    target tries to copy the runtimes/win/lib/netstandard2.0/ DLL to the bin folder,
    but the .NET 8 build does not emit this file in the inner project output.

    This target ensures the DLL is present before _FunctionsPostBuildCopyFiles runs.
    The DLL is sourced directly from the NuGet package cache.
  -->
  <Target Name="EnsureProtectedDataRuntimeDll"
          BeforeTargets="_FunctionsPostBuildCollectFiles">
    <PropertyGroup>
      <_PdSrc>$(USERPROFILE)\.nuget\packages\system.security.cryptography.protecteddata\4.7.0\runtimes\win\lib\netstandard2.0\System.Security.Cryptography.ProtectedData.dll</_PdSrc>
      <_PdDst>$(OutDir)runtimes\win\lib\netstandard2.0\</_PdDst>
    </PropertyGroup>
    <MakeDir Directories="$(_PdDst)" Condition="Exists('$(_PdSrc)') And !Exists('$(_PdDst)')" />
    <Copy SourceFiles="$(_PdSrc)"
          DestinationFolder="$(_PdDst)"
          Condition="Exists('$(_PdSrc)') And !Exists('$(_PdDst)System.Security.Cryptography.ProtectedData.dll')"
          SkipUnchangedFiles="true" />
  </Target>
</Project>
