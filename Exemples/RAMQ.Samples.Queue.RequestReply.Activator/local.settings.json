{
  "IsEncrypted": false,
  "Values": {
    "AzureWebJobsStorage": "UseDevelopmentStorage=true",
    "FUNCTIONS_WORKER_RUNTIME": "dotnet-isolated",
    "ServiceBusConnection__fullyQualifiedNamespace": "sb-wrapca.servicebus.windows.net"
  },
  "AppSettings": {
    "ServiceBusNamespace": "sb-wrapca.servicebus.windows.net",
    "Endpoints": [
      {
        "Target": "RequestReplyConsumerComplete",
        "Endpoint": {
          "EntityName": "simple.consumercomplete-queue",
          "EntityType": "Queue",
          "EnableSession": true
        }
      },
      {
        "Target": "reply-queue",
        "Endpoint": {
          "EntityName": "simple.consumercomplete_replyto-queue",
          "EntityType": "Queue",
          "EnableSession": true
        }
      }
    ],
    "ApplicationName": "Request Reply Activator",
    "MessageTransitJournalName": "COMJournalAISUnit",
    "MessageTransitJournalStoreUri": "https://stxalpum.table.core.windows.net"
  },
  "BlobStorageSetting": {
    "BlobServiceUri": "https://stxalpum.blob.core.windows.net",
    "ContainerName": "claimcheck",
    "FolderName": "messages",
    "ClaimCheckThresholdBytes": 262144
  }
}
